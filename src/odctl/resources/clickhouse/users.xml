<?xml version="1.0"?>
<clickhouse>
    <profiles>
        <default>
            <max_memory_usage>3758096384</max_memory_usage>
            <use_uncompressed_cache>0</use_uncompressed_cache>
            <load_balancing>in_order</load_balancing>
            <log_queries>1</log_queries>

            <receive_timeout>300</receive_timeout>
            <send_timeout>300</send_timeout>
            <max_execution_time>0</max_execution_time>
            <timeout_before_checking_execution_speed>60</timeout_before_checking_execution_speed>

            <async_insert>1</async_insert>
            <wait_for_async_insert>0</wait_for_async_insert>
            <min_insert_block_size_rows>1048576</min_insert_block_size_rows>
        </default>
    </profiles>

    <users>
        <default replace="replace">
            <password>password</password>
            <profile>default</profile>
            <networks>
                <ip>::/0</ip>
                <ip>0.0.0.0/0</ip>
            </networks>
            <quota>default</quota>
        </default>

        <user replace="replace">
            <password>password</password>
            <profile>default</profile>
            <networks>
                <ip>::/0</ip>
                <ip>0.0.0.0/0</ip>
            </networks>
            <quota>default</quota>
            <access_management>1</access_management>
        </user>
    </users>

    <quotas>
        <default>
            <interval>
                <duration>3600</duration>
                <queries>0</queries>
                <errors>0</errors>
                <result_rows>0</result_rows>
                <read_rows>0</read_rows>
                <execution_time>0</execution_time>
            </interval>
        </default>
    </quotas>
</clickhouse>
